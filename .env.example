# Copy to .env.local and fill in. Never commit .env.local.

# Required: OpenAI API key for embeddings, Vision OCR, and reasoning model.
# Create one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: override the embedding model. Brief allows text-embedding-3-small or text-embedding-3-large.
EMBEDDING_MODEL=text-embedding-3-small

# Optional: override the reasoning model used by the agent.
REASONING_MODEL=gpt-4o

# Optional: override the Vision OCR model used for scanned PDF pages.
VISION_OCR_MODEL=gpt-4o-mini

# Optional: maximum accepted upload size in bytes. Defaults to 50 MiB.
MAX_UPLOAD_BYTES=52428800

# Optional: maximum number of concurrent ingestion jobs (CSV/PDF) the upload
# handler will run at once. Excess uploads queue until a slot frees. Keep small;
# the in-memory store and Vision OCR pipeline assume a single-user workload.
UPLOAD_INGEST_CONCURRENCY=2
